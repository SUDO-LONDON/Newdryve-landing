# Canonical public site URL, used in metadata, OG tags, robots.txt, sitemap.xml, JSON-LD
NEXT_PUBLIC_SITE_URL=https://newdryve.com

# Dashboard / login app URL, landing CTAs link here (separate repo / subdomain)
NEXT_PUBLIC_APP_URL=https://app.newdryve.com

# --- Waitlist email (Resend) ---------------------------------------------
# Get this from https://resend.com/api-keys
# Without it, signups are accepted and logged to the server console but no email is sent.
RESEND_API_KEY=

# Where lead notifications are delivered. Defaults to hello@newdryve.com.
WAITLIST_NOTIFY_EMAIL=hello@newdryve.com

# "From" address for both the lead notification and the applicant confirmation.
# For testing without a verified domain, use: Newdryve <onboarding@resend.dev>
# (this only delivers to the Resend account owner's email)
# For production, verify your domain at https://resend.com/domains then use e.g.
# Newdryve <hello@newdryve.com>
WAITLIST_FROM_EMAIL=Newdryve <onboarding@resend.dev>

# Where replies to the applicant confirmation go. Defaults to WAITLIST_NOTIFY_EMAIL.
WAITLIST_REPLY_TO=hello@newdryve.com
