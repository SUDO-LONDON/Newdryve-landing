# Canonical public site URL, used in metadata, OG tags, robots.txt, sitemap.xml, JSON-LD
NEXT_PUBLIC_SITE_URL=https://newdryve.com

# Dashboard / login app URL, landing CTAs link here (separate repo / subdomain)
NEXT_PUBLIC_APP_URL=https://app.newdryve.com

# Existing backend origin. Used by Next rewrites so newdryve.com/v1/*,
# /healthz, and /readyz continue to reach the Fastify API service.
BACKEND_ORIGIN=https://your-backend-service.up.railway.app

# --- Waitlist email (Resend) ---------------------------------------------
# Get this from https://resend.com/api-keys
# Without it, signups are accepted and logged to the server console but no email is sent.
RESEND_API_KEY=

# Where lead notifications are delivered. Defaults to hello@newdryve.com.
WAITLIST_NOTIFY_EMAIL=hello@newdryve.com

# "From" address for both the lead notification and the applicant confirmation.
# For testing without a verified domain, use: Newdryve <onboarding@resend.dev>
# (this only delivers to the Resend account owner's email)
# For production, verify your domain at https://resend.com/domains then use e.g.
# Newdryve <hello@newdryve.com>
WAITLIST_FROM_EMAIL=Newdryve <onboarding@resend.dev>

# Where replies to the applicant confirmation go. Defaults to WAITLIST_NOTIFY_EMAIL.
WAITLIST_REPLY_TO=hello@newdryve.com

# --- Ops Portal (/ops) — founder-only internal portal --------------------
# Dedicated Supabase project "newdryve-ops" (kept separate from the live
# product DB). Create at https://supabase.com/dashboard then copy the values
# from Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# SECRET service-role key. Server-only. Never commit a real value or expose it
# to the browser. Used for signed data-room URLs, storage writes, audit log and
# GDPR deletes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Founder allowlist. ONLY these emails may authenticate into /ops. Enforced at
# middleware AND (seeded into ops_allowlist) at the RLS layer — keep in sync
# with the allowlist seed migration.
OPS_FOUNDER_ALLOWLIST=sinan@newdryve.com,deniz@newdryve.com,jed@newdryve.com,kurtish@newdryve.com

# Inactivity timeout (minutes) before a founder must re-authenticate.
OPS_SESSION_TIMEOUT_MINUTES=30
